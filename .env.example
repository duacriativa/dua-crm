# ─── Banco de Dados ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dua_crm"
POSTGRES_USER=dua_crm
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=dua_crm

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=troque_esta_senha

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api-dua-crm.railway.app

# ─── Encryption (AES-256 para dados sensíveis) ────────────────────────────────
ENCRYPTION_KEY=chave_de_32_caracteres_exatamente

# ─── Evolution API (WhatsApp) ─────────────────────────────────────────────────
EVOLUTION_API_URL=https://sua-evolution-api.railway.app
EVOLUTION_API_KEY=sua_chave_aqui
